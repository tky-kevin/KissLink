<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/notion_bg">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/btnMyCardBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:padding="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="我的名片"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/notion_text_primary"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnEditCard"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="編輯"
            android:textColor="?attr/colorPrimary"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:clipChildren="false">

            <!-- View mode: card preview -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/viewModeContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/notion_card"
                android:layout_marginBottom="16dp"
                android:clipToOutline="true"
                android:elevation="2dp">

                <!-- Colored header strip -->
                <View
                    android:id="@+id/cardHeaderStrip"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:background="?attr/colorPrimary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- Avatar overlapping strip -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivCardAvatar"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/avatar_placeholder"
                    android:elevation="4dp"
                    android:layout_marginTop="24dp"
                    app:shapeAppearance="@style/CircleShapeAppearance"
                    app:strokeWidth="3dp"
                    app:strokeColor="@color/notion_surface"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- Name -->
                <TextView
                    android:id="@+id/tvCardName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/notion_text_primary"
                    android:gravity="center"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintTop_toBottomOf="@id/ivCardAvatar"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- Bio -->
                <TextView
                    android:id="@+id/tvCardBio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/notion_text_secondary"
                    android:gravity="center"
                    android:maxLines="3"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintTop_toBottomOf="@id/tvCardName"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- Info rows -->
                <LinearLayout
                    android:id="@+id/cardInfoRows"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="24dp"
                    app:layout_constraintTop_toBottomOf="@id/tvCardBio"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <LinearLayout
                        android:id="@+id/rowSchool"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_width="24dp"
                            android:layout_height="wrap_content"
                            android:text="🎓"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tvCardSchoolMajor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/notion_text_secondary"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowIg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_width="24dp"
                            android:layout_height="wrap_content"
                            android:text="📸"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tvCardIg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="?attr/colorPrimary"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowLine"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_width="24dp"
                            android:layout_height="wrap_content"
                            android:text="💬"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tvCardLine"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/notion_text_secondary"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Edit mode container -->
            <LinearLayout
                android:id="@+id/editModeContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:background="@drawable/notion_card"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="姓名"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/notion_text_primary"/>
                    <EditText
                        android:id="@+id/etMyCardName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:textSize="14sp"
                        android:textColor="@color/notion_text_primary"
                        android:hint="姓名"
                        android:background="@android:color/transparent"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/notion_border"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="簡介"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/notion_text_primary"/>
                    <EditText
                        android:id="@+id/etMyCardBio"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="textMultiLine"
                        android:maxLines="3"
                        android:textSize="14sp"
                        android:textColor="@color/notion_text_primary"
                        android:hint="一句話介紹自己"
                        android:background="@android:color/transparent"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/notion_border"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="學校"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/notion_text_primary"/>
                    <EditText
                        android:id="@+id/etMyCardSchool"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="textCapWords"
                        android:maxLines="1"
                        android:textSize="14sp"
                        android:textColor="@color/notion_text_primary"
                        android:hint="就讀學校"
                        android:background="@android:color/transparent"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/notion_border"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="科系"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/notion_text_primary"/>
                    <EditText
                        android:id="@+id/etMyCardMajor"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="textCapWords"
                        android:maxLines="1"
                        android:textSize="14sp"
                        android:textColor="@color/notion_text_primary"
                        android:hint="主修科系"
                        android:background="@android:color/transparent"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/notion_border"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Instagram"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/notion_text_primary"/>
                    <EditText
                        android:id="@+id/etMyCardIg"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textSize="14sp"
                        android:textColor="@color/notion_text_primary"
                        android:hint="@username"
                        android:background="@android:color/transparent"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/notion_border"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Line ID"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/notion_text_primary"/>
                    <EditText
                        android:id="@+id/etMyCardLineId"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textSize="14sp"
                        android:textColor="@color/notion_text_primary"
                        android:hint="Line 帳號"
                        android:background="@android:color/transparent"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
