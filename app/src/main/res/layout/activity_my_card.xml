<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/notion_bg">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/btnMyCardBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:padding="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="我的名片"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/notion_text_primary"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnShareCard"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="分享"
            android:textColor="?attr/colorPrimary"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnEditCard"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="編輯"
            android:textColor="?attr/colorPrimary"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:clipChildren="false">

            <!-- View mode: card preview (信用卡樣式) -->
            <include
                android:id="@+id/viewModeContainer"
                layout="@layout/view_business_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"/>

            <!-- Edit mode container -->
            <LinearLayout
                android:id="@+id/editModeContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:background="@drawable/notion_card"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="姓名"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/notion_text_primary"/>
                    <EditText
                        android:id="@+id/etMyCardName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:textSize="14sp"
                        android:textColor="@color/notion_text_primary"
                        android:hint="姓名"
                        android:background="@android:color/transparent"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/notion_border"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="簡介"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/notion_text_primary"/>
                    <EditText
                        android:id="@+id/etMyCardBio"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="textMultiLine"
                        android:maxLines="3"
                        android:textSize="14sp"
                        android:textColor="@color/notion_text_primary"
                        android:hint="一句話介紹自己"
                        android:background="@android:color/transparent"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/notion_border"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="學校"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/notion_text_primary"/>
                    <EditText
                        android:id="@+id/etMyCardSchool"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="textCapWords"
                        android:maxLines="1"
                        android:textSize="14sp"
                        android:textColor="@color/notion_text_primary"
                        android:hint="就讀學校"
                        android:background="@android:color/transparent"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/notion_border"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="科系"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/notion_text_primary"/>
                    <EditText
                        android:id="@+id/etMyCardMajor"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="textCapWords"
                        android:maxLines="1"
                        android:textSize="14sp"
                        android:textColor="@color/notion_text_primary"
                        android:hint="主修科系"
                        android:background="@android:color/transparent"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/notion_border"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Instagram"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/notion_text_primary"/>
                    <EditText
                        android:id="@+id/etMyCardIg"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textSize="14sp"
                        android:textColor="@color/notion_text_primary"
                        android:hint="@username"
                        android:background="@android:color/transparent"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/notion_border"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Line ID"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/notion_text_primary"/>
                    <EditText
                        android:id="@+id/etMyCardLineId"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textSize="14sp"
                        android:textColor="@color/notion_text_primary"
                        android:hint="Line 帳號"
                        android:background="@android:color/transparent"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
