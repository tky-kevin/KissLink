<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/beam_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="10dp"
        android:paddingBottom="24dp">

        <!-- handle -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="18dp"
            android:background="@color/beam_track" />

        <!-- 標題列：標題 + 編輯/完成 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Beam.Label"
                android:text="@string/profile_title" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditToggle"
                style="@style/Beam.Button.Text.Base"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/beam_accent"
                android:textAllCaps="false"
                app:icon="@drawable/ic_edit"
                app:iconTint="@color/beam_accent"
                app:iconSize="16dp"
                android:text="@string/profile_edit" />
        </LinearLayout>

        <!-- 頭像 -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivCardAvatar"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_avatar"
                android:src="@drawable/ic_person"
                android:padding="26dp"
                app:strokeColor="@color/beam_track"
                app:strokeWidth="1.5dp"
                app:shapeAppearanceOverlay="@style/Beam.Avatar.Circle" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAvatarEditBadge"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/bg_avatar"
                android:src="@drawable/ic_edit"
                android:padding="7dp"
                android:visibility="gone"
                app:strokeColor="@color/beam_surface"
                app:strokeWidth="2dp"
                app:shapeAppearanceOverlay="@style/Beam.Avatar.Circle"
                tools:visibility="visible" />
        </FrameLayout>

        <!-- 姓名 -->
        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:background="@null"
            android:textColor="@color/beam_ink"
            android:textSize="24sp"
            android:textFontWeight="600"
            android:hint="@string/profile_name_hint"
            android:textColorHint="@color/beam_muted"
            android:inputType="textPersonName"
            android:maxLines="1"
            android:enabled="false"
            tools:text="王小明" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:background="@color/beam_track" />

        <!-- 欄位容器（程式動態填入 item_profile_field） -->
        <LinearLayout
            android:id="@+id/fieldsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="6dp" />

        <!-- 新增欄位（編輯模式） -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddField"
            style="@style/Beam.Button.Text.Base"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/beam_accent"
            android:textAllCaps="false"
            android:visibility="gone"
            app:icon="@drawable/ic_add"
            app:iconTint="@color/beam_accent"
            app:iconSize="18dp"
            android:text="@string/profile_add_field"
            tools:visibility="visible" />

        <!-- 傳送我的名片 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendCard"
            style="@style/Beam.PickButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            app:icon="@drawable/ic_send"
            app:iconTint="@color/beam_ink"
            android:text="@string/profile_send_self" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
