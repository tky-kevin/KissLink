<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beam_bg"
    android:fitsSystemWindows="true">

    <!-- ══ 頂列 ══════════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tvWordmark"
        style="@style/Beam.Wordmark"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:text="@string/app_name"
        android:layout_marginStart="20dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <FrameLayout
        android:id="@+id/avatarFrame"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="16dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="@id/tvWordmark"
        app:layout_constraintBottom_toBottomOf="@id/tvWordmark"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 邊框環：ring drawable，不受 ShapeableImageView clip 影響 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_avatar_ring" />

        <!-- 頭像：縮進 2dp 讓邊框環可見 -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_avatar"
            android:src="@drawable/ic_avatar_default"
            android:padding="6dp"
            android:contentDescription="@string/cd_avatar"
            app:shapeAppearanceOverlay="@style/Beam.Avatar.Circle" />
    </FrameLayout>

    <ImageButton
        android:id="@+id/ibSettings"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="2dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_settings"
        android:scaleType="fitCenter"
        android:padding="10dp"
        android:contentDescription="@string/cd_settings"
        app:layout_constraintTop_toTopOf="@id/avatarFrame"
        app:layout_constraintBottom_toBottomOf="@id/avatarFrame"
        app:layout_constraintEnd_toStartOf="@id/ibHistory" />

    <ImageButton
        android:id="@+id/ibHistory"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_history"
        android:scaleType="centerInside"
        android:contentDescription="@string/cd_history"
        app:layout_constraintTop_toTopOf="@id/avatarFrame"
        app:layout_constraintBottom_toBottomOf="@id/avatarFrame"
        app:layout_constraintEnd_toStartOf="@id/avatarFrame" />

    <!-- ══ 下方面板（headline + 內容 + 按鈕）固定在底，Beam 撐滿其上空間 ══ -->
    <LinearLayout
        android:id="@+id/lowerPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="20dp"
        android:animateLayoutChanges="true"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- headline 區（文字大標 與 百分比大字 疊放，互斥顯示） -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp">

            <TextView
                android:id="@+id/tvHeadline"
                style="@style/Beam.Headline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/home_ready_title" />

            <LinearLayout
                android:id="@+id/percentRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/tvPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/beam_ink"
                    android:textSize="72sp"
                    android:textFontWeight="200"
                    android:letterSpacing="-0.03"
                    android:includeFontPadding="false"
                    android:fontFeatureSettings="tnum"
                    tools:text="87" />

                <TextView
                    android:id="@+id/tvPercentUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:layout_marginBottom="12dp"
                    android:textColor="@color/beam_muted"
                    android:textSize="22sp"
                    android:textFontWeight="300"
                    android:text="%" />
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/tvSub"
            style="@style/Beam.Sub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/home_ready_sub" />

        <!-- 待傳項目（疊起來、固定高度；點擊彈出完整清單）design B -->
        <FrameLayout
            android:id="@+id/sendStackRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_chip"
            android:foreground="@drawable/ripple_chip"
            android:clickable="true"
            android:focusable="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 文字靠左 -->
                <TextView
                    android:id="@+id/tvStackLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:textColor="@color/beam_ink"
                    android:textSize="15sp"
                    android:textFontWeight="600"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="3 個待傳項目" />

                <!-- 檔案圖示（疊起來）在文字右側 -->
                <FrameLayout
                    android:id="@+id/stackThumbs"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp" />

                <!-- 撐開：把「查看」推到尾端 -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:includeFontPadding="false"
                    android:textColor="@color/beam_accent"
                    android:textSize="14sp"
                    android:textFontWeight="600"
                    android:text="@string/view_batch" />
            </LinearLayout>
        </FrameLayout>

        <!-- 傳輸中：待傳清單展開成的「列表方塊」（無標題、當前列高亮、上下淡出邊緣可滑）。
             高度由程式依項目數設定（上限約 3 列）。 -->
        <!-- 上下 padding 必須為 0：Android 內建淡出邊是從 paddingTop/Bottom 起算，
             有上下 padding 就會把淡出帶推離圓角邊緣（不貼齊）。上下留白改由 ItemDecoration 提供；
             左右用 padding 給寬一點的內距。overScrollMode 開啟 → 捲到底有邊緣回饋。 -->
        <com.kisslink.ui.home.MaxHeightRecyclerView
            android:id="@+id/rvTransfer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_chip"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:overScrollMode="ifContentScrolls"
            android:requiresFadingEdge="vertical"
            android:fadingEdgeLength="28dp"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- 接收方：收到一包檔案 — 與「待傳方塊」共用同一設計語彙（前導圖｜靠左標題｜查看），
             整塊可點 → 開啟該批次。 -->
        <LinearLayout
            android:id="@+id/receivedBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_chip"
            android:foreground="@drawable/ripple_chip"
            android:clickable="true"
            android:focusable="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- 文字靠左 -->
            <TextView
                android:id="@+id/tvReceived"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:textColor="@color/beam_ink"
                android:textSize="15sp"
                android:textFontWeight="600"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="收到 3 個項目" />

            <!-- 下載圖示在文字右側（樣式與「待傳方塊」的疊圖一致：純圖示、40dp、置中內縮） -->
            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:scaleType="centerInside"
                android:padding="9dp"
                android:src="@drawable/ic_received"
                app:shapeAppearanceOverlay="@style/Beam.Thumb.Rounded" />

            <!-- 撐開：把「查看」推到尾端 -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:includeFontPadding="false"
                android:textColor="@color/beam_accent"
                android:textSize="14sp"
                android:textFontWeight="600"
                android:text="@string/view_batch" />
        </LinearLayout>

        <!-- 內容選擇 -->
        <LinearLayout
            android:id="@+id/pickRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickFiles"
                style="@style/Beam.PickButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="@string/pick_files"
                app:icon="@drawable/ic_file" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickMedia"
                style="@style/Beam.PickButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="@string/pick_media"
                app:icon="@drawable/ic_image" />
        </LinearLayout>

        <!-- 傳送（已選且已連線才顯示） -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            style="@style/Beam.SendButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            app:icon="@drawable/ic_send"
            tools:visibility="visible"
            tools:text="傳送 3 個項目" />
    </LinearLayout>

    <!-- ══ 中央 Beam ══════════════════════════════════════════ -->
    <com.kisslink.ui.home.BeamStageView
        android:id="@+id/beam"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvWordmark"
        app:layout_constraintBottom_toTopOf="@id/lowerPanel" />

</androidx.constraintlayout.widget.ConstraintLayout>
