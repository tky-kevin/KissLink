<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_send_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_send"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_pick_file"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_pick_file"
        android:backgroundTint="@color/primary"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tv_nfc_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tap_nfc_hint"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_files"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/surface"
        android:layout_marginBottom="12dp" />

    <ProgressBar
        android:id="@+id/progress_send"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="0"
        android:visibility="gone"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_start_send"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_start_send"
        android:textSize="16sp"
        android:backgroundTint="@color/primary"
        android:enabled="false" />

</LinearLayout>
