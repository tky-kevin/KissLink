<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/notion_bg">

    <!-- 名片卡片（動畫目標）：垂直置中 -->
    <include
        android:id="@+id/cardAnimRoot"
        layout="@layout/view_business_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardDisplayDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.45"/>

    <!-- 分隔線 -->
    <View
        android:id="@+id/cardDisplayDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/notion_border"
        app:layout_constraintBottom_toTopOf="@id/btnSaveToContacts"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>

    <!-- 儲存至通訊錄按鈕 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveToContacts"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="💾 儲存至通訊錄"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="?attr/colorPrimary"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toTopOf="@id/btnDisplayBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="8dp"/>

    <!-- 關閉按鈕 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDisplayBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="關閉"
        style="@style/Widget.Material3.Button.TextButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
