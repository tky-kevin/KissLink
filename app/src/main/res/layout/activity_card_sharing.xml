<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/notion_bg">

    <!-- 名片卡片（動畫目標）：垂直置中略偏上 -->
    <include
        android:id="@+id/cardAnimRoot"
        layout="@layout/view_business_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvSharingStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.45"/>

    <!-- 分享狀態文字 -->
    <TextView
        android:id="@+id/tvSharingStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="等待對方靠近..."
        android:textSize="16sp"
        android:textColor="@color/notion_text_primary"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/cardAnimRoot"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="36dp"/>

    <!-- 提示文字 -->
    <TextView
        android:id="@+id/tvSharingHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⊙ 輕輕碰觸兩台手機"
        android:textSize="14sp"
        android:textColor="@color/notion_text_secondary"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvSharingStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- 取消按鈕 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCardSharingCancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="取消"
        style="@style/Widget.Material3.Button.TextButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="48dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
