<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/notion_bg">

    <!-- Outer ring -->
    <View
        android:id="@+id/sharingRing3"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:background="@drawable/nfc_ring"
        android:alpha="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="60dp"/>

    <View
        android:id="@+id/sharingRing2"
        android:layout_width="170dp"
        android:layout_height="170dp"
        android:background="@drawable/nfc_ring"
        android:alpha="0.3"
        app:layout_constraintTop_toTopOf="@id/sharingRing3"
        app:layout_constraintBottom_toBottomOf="@id/sharingRing3"
        app:layout_constraintStart_toStartOf="@id/sharingRing3"
        app:layout_constraintEnd_toEndOf="@id/sharingRing3"/>

    <!-- Center: mini card preview -->
    <FrameLayout
        android:id="@+id/sharingRing1"
        android:layout_width="88dp"
        android:layout_height="88dp"
        app:layout_constraintTop_toTopOf="@id/sharingRing3"
        app:layout_constraintBottom_toBottomOf="@id/sharingRing3"
        app:layout_constraintStart_toStartOf="@id/sharingRing3"
        app:layout_constraintEnd_toEndOf="@id/sharingRing3">

        <View
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:background="@drawable/notion_card"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivSharingAvatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:scaleType="centerCrop"
                android:src="@drawable/avatar_placeholder"
                app:shapeAppearance="@style/CircleShapeAppearance"/>

            <TextView
                android:id="@+id/tvSharingName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="@color/notion_text_primary"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Hint text -->
    <TextView
        android:id="@+id/tvSharingHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/card_sharing_hint"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/notion_text_primary"
        android:gravity="center"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        app:layout_constraintTop_toBottomOf="@id/sharingRing3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <TextView
        android:id="@+id/tvSharingSubHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="等待對方靠近…"
        android:textSize="14sp"
        android:textColor="@color/notion_text_tertiary"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvSharingHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCardSharingCancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_cancel"
        style="@style/Widget.Material3.Button.TextButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="48dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
