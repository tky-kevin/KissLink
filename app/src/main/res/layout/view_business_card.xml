<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/businessCardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardBackgroundColor="?attr/colorPrimary"
    app:cardElevation="12dp"
    android:layout_marginStart="24dp"
    android:layout_marginEnd="24dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Avatar (圓形, 80dp) -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivCardAvatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:src="@drawable/avatar_placeholder"
            app:shapeAppearance="@style/CircleShapeAppearance"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- 姓名 -->
        <TextView
            android:id="@+id/tvCardName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="@id/ivCardAvatar"
            app:layout_constraintStart_toEndOf="@id/ivCardAvatar"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 學校 · 科系 -->
        <TextView
            android:id="@+id/tvCardSchoolMajor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#CCFFFFFF"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvCardName"
            app:layout_constraintStart_toEndOf="@id/ivCardAvatar"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Bio -->
        <TextView
            android:id="@+id/tvCardBio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#CCFFFFFF"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/ivCardAvatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 分隔線 -->
        <View
            android:id="@+id/cardDivider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvCardBio"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- IG（左下） -->
        <TextView
            android:id="@+id/tvCardIg"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/cardDivider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvCardLine"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="0dp"/>

        <!-- LINE（右下） -->
        <TextView
            android:id="@+id/tvCardLine"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="end"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/cardDivider"
            app:layout_constraintStart_toEndOf="@id/tvCardIg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
