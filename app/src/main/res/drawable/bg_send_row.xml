<?xml version="1.0" encoding="utf-8"?>
<!-- 清單列底：圓角點擊 ripple + activated 狀態圓角高亮（傳輸中當前列 accent_soft）。
     圓角半徑與全 app 整列點擊回饋一致（@dimen/row_corner_radius）。 -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="?attr/colorControlHighlight">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/row_corner_radius" />
            <solid android:color="#FFFFFFFF" />
        </shape>
    </item>
    <item>
        <!-- enter/exit fade：切換 activated 高亮底色時做淡入淡出，而非瞬間變色。 -->
        <selector android:enterFadeDuration="220" android:exitFadeDuration="220">
            <item android:state_activated="true">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/row_corner_radius" />
                    <solid android:color="@color/beam_accent_soft" />
                </shape>
            </item>
            <item>
                <color android:color="@android:color/transparent" />
            </item>
        </selector>
    </item>
</ripple>
