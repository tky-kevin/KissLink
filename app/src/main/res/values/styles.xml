<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 微標籤：大寫、寬字距、次要色（Beam 編輯感） -->
    <style name="Beam.Label" parent="">
        <item name="android:textColor">@color/beam_muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineHeight">16sp</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:letterSpacing">0.18</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">@font/zpix</item>
    </style>

    <!-- 大標：中等字重 -->
    <style name="Beam.Headline" parent="">
        <item name="android:textColor">@color/beam_ink</item>
        <item name="android:textSize">28sp</item>
        <item name="android:lineHeight">44sp</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:fontFamily">@font/zpix</item>
    </style>

    <!-- 副標 -->
    <style name="Beam.Sub" parent="">
        <item name="android:textColor">@color/beam_muted</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">24sp</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:fontFamily">@font/zpix</item>
    </style>

    <!-- App wordmark（左上） -->
    <style name="Beam.Wordmark" parent="">
        <item name="android:textColor">@color/beam_ink</item>
        <item name="android:textSize">20dp</item>
        <item name="android:lineHeight">28dp</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:fontFamily">@font/zpix</item>
    </style>

    <!-- 內容選擇 pill（外框） -->
    <style name="Beam.PickButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textFontWeight">600</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/beam_ink</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/zpix</item>
        <item name="android:includeFontPadding">false</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="strokeColor">@color/beam_track</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">26dp</item>
        <item name="iconTint">@color/beam_ink</item>
        <item name="iconGravity">textStart</item>
        <item name="iconSize">18dp</item>
        <item name="rippleColor">@color/beam_accent_soft</item>
    </style>

    <!-- 圓形頭像 -->
    <style name="Beam.Avatar.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- 縮圖圓角 -->
    <style name="Beam.Thumb.Rounded" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

    <!-- 傳送 pill（古銅金填充） -->
    <style name="Beam.SendButton" parent="Widget.Material3.Button">
        <item name="android:textFontWeight">700</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/zpix</item>
        <item name="android:includeFontPadding">false</item>
        <item name="backgroundTint">@color/beam_accent</item>
        <item name="android:textColor">@color/beam_on_accent</item>
        <item name="cornerRadius">28dp</item>
        <item name="iconTint">@color/beam_on_accent</item>
        <item name="iconGravity">textStart</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Beam.CardActionButton.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textFontWeight">600</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/beam_ink</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/zpix</item>
        <item name="android:includeFontPadding">false</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="strokeColor">@color/beam_track</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">26dp</item>
        <item name="iconTint">@color/beam_ink</item>
        <item name="iconGravity">textStart</item>
        <item name="iconSize">18dp</item>
        <item name="rippleColor">@color/beam_accent_soft</item>
    </style>

    <style name="Beam.CardActionButton.Filled" parent="Widget.Material3.Button">
        <item name="android:textFontWeight">600</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/beam_on_accent</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/zpix</item>
        <item name="android:includeFontPadding">false</item>
        <item name="backgroundTint">@color/beam_accent</item>
        <item name="cornerRadius">26dp</item>
        <item name="iconTint">@color/beam_on_accent</item>
        <item name="iconGravity">textStart</item>
        <item name="iconSize">18dp</item>
        <item name="elevation">0dp</item>
        <item name="rippleColor">@color/beam_accent_soft</item>
    </style>
</resources>
