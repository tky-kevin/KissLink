<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.KissLink" parent="Theme.Material3.Light.NoActionBar">
        <!-- 全域 zpix 字體 -->
        <item name="android:fontFamily">@font/zpix</item>
        <item name="fontFamily">@font/zpix</item>

        <item name="colorPrimary">@color/beam_accent</item>
        <item name="colorOnPrimary">@color/beam_on_accent</item>
        <item name="colorSecondary">@color/beam_accent</item>
        <item name="colorOnSecondary">@color/beam_on_accent</item>
        <item name="android:colorBackground">@color/beam_bg</item>
        <item name="colorSurface">@color/beam_surface</item>
        <item name="colorOnSurface">@color/beam_ink</item>
        <item name="colorOnSurfaceVariant">@color/beam_muted</item>
        <item name="colorOutline">@color/beam_track</item>
        <item name="colorError">@color/beam_error</item>

        <!-- 狀態列／導覽列：透明、深色圖示，融進暖米底 -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/beam_bg</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <!-- Bottom sheet 樣式 -->
        <item name="bottomSheetStyle">@style/Beam.BottomSheet.Modal</item>

        <!-- 全域按鈕樣式 -->
        <item name="materialButtonStyle">@style/Beam.Button.Base</item>

        <!-- 全域對話框樣式（標題／內文行距統一） -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Beam.Dialog</item>

        <!-- 全域 TextView 樣式（移除額外字體邊距，確保 zpix 置中） -->
        <item name="android:textViewStyle">@style/Beam.TextView.Base</item>
    </style>

    <!-- AvatarCropActivity: 透明視窗背景避免與根佈局黑色背景重疊繪製 -->
    <style name="Theme.KissLink.TransparentWindow" parent="Theme.KissLink">
        <item name="android:windowBackground">@null</item>
    </style>

    <!-- 全域按鈕基底樣式 -->
    <style name="Beam.Button.Base" parent="Widget.Material3.Button">
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="Beam.Button.Text.Base" parent="Widget.Material3.Button.TextButton">
        <item name="android:includeFontPadding">false</item>
    </style>

    <!-- 全域 TextView 基底樣式 -->
    <style name="Beam.TextView.Base" parent="android:Widget.TextView">
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="Theme.KissLink.BottomSheet" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Beam.BottomSheet.Modal</item>
    </style>

    <style name="Beam.BottomSheet.Modal" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">@color/beam_surface</item>
        <item name="shapeAppearance">@style/Beam.Shape.Sheet</item>
    </style>

    <style name="Beam.Shape.Sheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- 置中卡片對話框（名片）：透明浮動視窗，背景暗化＋模糊由程式設定 -->
    <style name="Theme.KissLink.CardDialog" parent="Theme.Material3.Light.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="colorPrimary">@color/beam_accent</item>
        <item name="colorOnPrimary">@color/beam_on_accent</item>
        <item name="colorSurface">@color/beam_surface</item>
        <item name="colorOnSurface">@color/beam_ink</item>
    </style>
</resources>
