<?xml version="1.0" encoding="utf-8"?>
<!--
    KissLink HCE 自訂 AID 宣告。
    AID F04B495353 = F0(私有前綴) + "KISS" ASCII。
    使用私有 AID(而非標準 NDEF AID D2760000850101)以避免與系統內建的
    NdefNfceeService(「嵌入式標記」)搶同一 AID 而跳卡片模擬衝突選擇器。
    category="other" 表示非支付用途，不與系統錢包衝突。
-->
<host-apdu-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/app_name"
    android:requireDeviceUnlock="false">

    <aid-group
        android:category="other"
        android:description="@string/app_name">

        <aid-filter android:name="F04B495353"/>

    </aid-group>

</host-apdu-service>
